{
  "manifest_version": 3,
  "name": "Wadjet",
  "version": "1.1.0",
  "description": "Case-bound investigation console for security analysts.",
  "browser_specific_settings": {
    "gecko": {
      "id": "{d1e43b9f-a247-4a05-98e8-696b4ff6740b}",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": ["websiteActivity"]
      }
    }
  },
  "icons": {
    "16": "icons/wadjet-compact.svg",
    "32": "icons/wadjet-compact.svg",
    "48": "icons/wadjet.svg",
    "96": "icons/wadjet.svg",
    "128": "icons/wadjet.svg"
  },
  "permissions": [
    "storage",
    "webRequest",
    "webRequestBlocking",
    "menus",
    "activeTab",
    "scripting",
    "contextualIdentities",
    "cookies",
    "downloads",
    "nativeMessaging"
  ],
  "devtools_page": "devtools/devtools.html",
  "optional_host_permissions": [
    "<all_urls>",
    "https://www.virustotal.com/*",
    "https://otx.alienvault.com/*",
    "https://api.abuseipdb.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "sidebar_action": {
    "default_title": "Wadjet",
    "default_panel": "sidebar/index.html",
    "default_icon": {
      "16": "icons/wadjet-compact.svg",
      "32": "icons/wadjet-compact.svg",
      "48": "icons/wadjet.svg"
    }
  }
}
